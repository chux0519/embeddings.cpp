{
  "name": "@embeddings-cpp/web",
  "version": "0.1.1",
  "description": "Browser-first Snowflake embedding client for embeddings.cpp",
  "homepage": "https://github.com/chux0519/embeddings.cpp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chux0519/embeddings.cpp.git",
    "directory": "packages/web"
  },
  "bugs": {
    "url": "https://github.com/chux0519/embeddings.cpp/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:dry-run": "npm pack --dry-run"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "keywords": [
    "embeddings",
    "snowflake",
    "browser",
    "wasm",
    "webgpu"
  ],
  "license": "MIT"
}
